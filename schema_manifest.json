{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "project": "erp_yummy",
  "version": "0.6.0",
  "last_updated": "2026-04-14",
  "session": 5,

  "environment": {
    "python": ".venv/python.exe",
    "venv_type": "conda",
    "backend_port": 2344,
    "frontend_port": 2347,
    "base_api_url": "http://127.0.0.1:2344/api/"
  },

  "backend": {
    "framework": "Django 6.0.3",
    "installed_apps": [
      "rest_framework",
      "corsheaders",
      "api"
    ],
    "cors_allowed_origins": [
      "http://localhost:2347",
      "http://127.0.0.1:2347"
    ],
    "database": {
      "engine": "sqlite3",
      "file": "backend/db.sqlite3",
      "migrated": true
    },
    "auth": {
      "package": "djangorestframework-simplejwt 5.5.1",
      "access_token_lifetime": "8 hours",
      "refresh_token_lifetime": "7 days",
      "login_field": "phone_number (USERNAME_FIELD on custom User model)",
      "test_account": {
        "phone_number": "0915085900",
        "password": "12345",
        "full_name": "Thao Vi",
        "create_command": "python manage.py create_test_user"
      }
    },
    "models": {
      "User": {
        "status": "done",
        "class": "api.models.User(AbstractUser)",
        "manager": "api.models.UserManager",
        "fields": {
          "phone_number": "CharField(max_length=20, unique=True) — USERNAME_FIELD",
          "full_name": "CharField(max_length=200, blank=True)",
          "email": "inherited from AbstractUser (optional)",
          "is_staff": "inherited",
          "is_active": "inherited"
        },
        "removed_fields": ["username"],
        "migration": "api/migrations/0001_initial.py",
        "note": "Custom User model. username=None, USERNAME_FIELD='phone_number', REQUIRED_FIELDS=[]"
      },
      "Product": {
        "status": "done",
        "migration": "api/migrations/0002_customer_product_order.py",
        "fields": {
          "code": "CharField(max_length=20, unique=True)",
          "name": "CharField(max_length=200)",
          "group": "CharField(max_length=100)",
          "unit": "CharField(max_length=50)",
          "quantity": "IntegerField(default=0) — so luong ton kho",
          "price": "DecimalField(max_digits=12, decimal_places=0)",
          "status": "CharField(choices=['active','inactive'], default='active')",
          "created_at": "DateTimeField(auto_now_add=True)",
          "updated_at": "DateTimeField(auto_now=True)"
        }
      },
      "Order": {
        "status": "done",
        "fields": {
          "code": "CharField(max_length=20, unique=True)",
          "customer": "ForeignKey(Customer)",
          "total": "DecimalField(max_digits=14, decimal_places=0)",
          "status": "CharField(choices=['pending','confirmed','delivered','cancelled'])",
          "created_at": "DateTimeField(auto_now_add=True)"
        }
      },
      "Customer": {
        "status": "done",
        "fields": {
          "name": "CharField(max_length=200)",
          "phone": "CharField(max_length=20)",
          "email": "EmailField(blank=True)",
          "address": "TextField(blank=True)"
        }
      }
    },
    "api_endpoints": [
      {
        "method": "POST",
        "url": "/api/auth/login/",
        "view": "PhoneLoginView",
        "auth": "public",
        "description": "Đăng nhập bằng phone + password → trả về access, refresh, user",
        "status": "done",
        "response": {
          "access": "JWT access token (8h)",
          "refresh": "JWT refresh token (7d)",
          "user": { "id": "int", "name": "string", "phone": "string", "is_staff": "bool" }
        }
      },
      {
        "method": "GET",
        "url": "/api/dashboard/",
        "view": "dashboard_stats",
        "auth": "Bearer",
        "description": "4 số liệu tổng quan từ DB thật: total_products, active_products, revenue_today, orders_today",
        "status": "done",
        "data_source": "real_db"
      },
      {
        "method": "GET",
        "url": "/api/products/",
        "view": "product_list",
        "auth": "Bearer",
        "description": "Danh sách thành phẩm từ DB, hỗ trợ ?search=",
        "status": "done",
        "data_source": "real_db"
      },
      {
        "method": "POST",
        "url": "/api/products/",
        "view": "product_list",
        "auth": "Bearer",
        "description": "Tạo sản phẩm mới",
        "status": "done"
      },
      {
        "method": "PUT",
        "url": "/api/products/{id}/",
        "view": "product_detail",
        "auth": "Bearer",
        "description": "Cập nhật toàn bộ sản phẩm",
        "status": "done"
      },
      {
        "method": "PATCH",
        "url": "/api/products/{id}/",
        "view": "product_detail",
        "auth": "Bearer",
        "description": "Cập nhật một phần sản phẩm",
        "status": "done"
      },
      {
        "method": "DELETE",
        "url": "/api/products/{id}/",
        "view": "product_detail",
        "auth": "Bearer",
        "description": "Xóa sản phẩm",
        "status": "done"
      },
      {
        "method": "GET",
        "url": "/api/orders/",
        "view": "order_list",
        "auth": "Bearer",
        "status": "done",
        "data_source": "real_db"
      },
      {
        "method": "GET",
        "url": "/api/customers/",
        "view": "customer_list",
        "auth": "Bearer",
        "status": "done",
        "data_source": "real_db"
      },
      {
        "method": "POST",
        "url": "/api/customers/",
        "view": "customer_list",
        "auth": "Bearer",
        "status": "done"
      },
      {
        "method": "POST",
        "url": "/api/products/sync/",
        "view": "product_sync",
        "auth": "Bearer",
        "description": "Doc data_sync/products.json, upsert theo id. Tra ve {updated, created, message}",
        "status": "done"
      }
    ]
  },

  "frontend": {
    "framework": "React 19 + Vite 8",
    "css": "TailwindCSS 3",
    "http_client": "axios",
    "icon_library": "lucide-react",
    "api_base": "src/api/axios.js",
    "entry": "src/main.jsx",
    "router": "state-based (no react-router-dom yet — TODO)",
    "auth_flow": "localStorage tokens → App.jsx state → LoginPage or HomePage",
    "components": [
      {
        "name": "LoginPage",
        "file": "src/pages/LoginPage.jsx",
        "description": "Split-screen: food photo CSS-cropped (left 50%), form on cream bg (right 50%)",
        "status": "done",
        "features": [
          "Phone input with Phone icon",
          "Password input with Lock icon + Eye toggle",
          "Loading spinner on submit",
          "Error display from API response",
          "Saves access_token, refresh_token, user to localStorage",
          "Demo credentials hint"
        ]
      },
      {
        "name": "HomePage",
        "file": "src/components/HomePage.jsx",
        "description": "Layout chính ERP: Sidebar + Header + page views. Nhận user + onLogout props",
        "status": "done",
        "sub_components": ["DashboardView", "ProductsView", "ComingSoonView"]
      },
      {
        "name": "DashboardView",
        "file": "src/components/HomePage.jsx (inline)",
        "description": "4 stat cards + danh sách hoạt động gần đây",
        "status": "done"
      },
      {
        "name": "ProductsView",
        "file": "src/components/HomePage.jsx (inline)",
        "description": "Bảng thành phẩm với search, pagination, action buttons",
        "status": "done",
        "note": "Mock data — thay bằng API call thật khi có Product model"
      },
      {
        "name": "ProductModal",
        "file": "src/components/ProductModal.jsx",
        "description": "Modal thêm/sửa sản phẩm",
        "status": "TODO"
      },
      {
        "name": "OrdersPage",
        "file": "src/pages/OrdersPage.jsx",
        "description": "Quản lý đơn hàng",
        "status": "TODO"
      },
      {
        "name": "CustomersPage",
        "file": "src/pages/CustomersPage.jsx",
        "description": "Quản lý khách hàng",
        "status": "TODO"
      }
    ]
  },

  "progress": {
    "completed_sessions": [
      {
        "session": 1,
        "date": "2026-04-13",
        "summary": "Project init: Django+CORS, Tailwind+Axios, HomePage ERP UI"
      },
      {
        "session": 2,
        "date": "2026-04-13",
        "summary": "JWT auth: simplejwt, PhoneLoginView, LoginPage split-screen UI, axios interceptors, App auth routing"
      },
      {
        "session": 3,
        "date": "2026-04-13",
        "summary": "Custom User model: phone_number as USERNAME_FIELD, DB reset+migrate, updated seed command, LoginPage payload fix. LOGIN FEATURE COMPLETE."
      }
    ],
    "next_steps": [
      "Xay dung Dashboard sau login: hien thi du lieu that tu DB",
      "Dinh nghia models: Product, Order, Customer trong api/models.py",
      "Chay makemigrations + migrate cho models moi",
      "Nang cap api/serializers.py cho tung model",
      "Nang cap API endpoints sang CRUD that (thay mock data)",
      "Them react-router-dom va tao cac pages rieng biet",
      "Modal them/sua san pham ket noi nut Tao lo",
      "Token refresh tu dong khi access token het han"
    ]
  }
}
